<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_TOBE_v2" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collaboration_TOBE_v2">
    <bpmn:participant id="Participant_Company" name="Employee Recruitment (TO-BE)" processRef="Process_TOBE_v2" />
    <bpmn:participant id="Participant_Applier" name="Applier" />
    <bpmn:participant id="Participant_19ekitq" name="HR Manager" processRef="Process_1omo9f6" />
    <bpmn:messageFlow id="MsgFlow_ApplierToProcess" name="Application submission" sourceRef="Participant_Applier" targetRef="Event_ApplicationReceived" />
    <bpmn:messageFlow id="MsgFlow_InterviewInvitation" name="Interview invitation" sourceRef="Task_ScheduleFirstInterview" targetRef="Participant_Applier" />
    <bpmn:messageFlow id="MsgFlow_Cancellation" name="Cancellation" sourceRef="Task_SendCancellation" targetRef="Participant_Applier" />
    <bpmn:messageFlow id="MsgFlow_SecondInterview" name="Assessment invitation" sourceRef="Task_ScheduleSecondInterview" targetRef="Participant_Applier" />
    <bpmn:messageFlow id="Flow_0og80vw" name="Contract" sourceRef="Task_SendContract" targetRef="Participant_Applier" />
    <bpmn:messageFlow id="Flow_0rsrf49" name="Contract" sourceRef="Participant_Applier" targetRef="Event_0h88k8b" />
  </bpmn:collaboration>
  <bpmn:process id="Process_TOBE_v2" isExecutable="true">
    <bpmn:laneSet id="LaneSet_TOBE_v2">
      <bpmn:lane id="Lane_HiringManager" name="Hiring Manager">
        <bpmn:flowNodeRef>Task_ConductFirstInterview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EvaluateCandidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_InviteSecondInterview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConductSecondInterview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_HireCandidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_13ubzbu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ScheduleSecondInterview</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_HRRecruiter" name="System">
        <bpmn:flowNodeRef>Task_CVScoring</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DMNShortlist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ApplicationSuitable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendCancellation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Denied</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ScheduleFirstInterview</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_HRManager" name="HR Manager">
        <bpmn:flowNodeRef>Event_ApplicationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GatherApplications</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CreateContract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendContract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0h88k8b</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TriggerOnboarding</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Onboarded</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="Flow_AfterSecondEvaluate" sourceRef="Task_EvaluateCandidate" targetRef="Gateway_HireCandidate" />
    <bpmn:intermediateCatchEvent id="Event_ApplicationReceived" name="Application received">
      <bpmn:documentation>
        AS-IS: HR Manager wartet manuell auf eingehende Bewerbungen per E-Mail.
        TO-BE: Make überwacht E-Mail-Postfach und Bewerbungsportal.
               Bei neuer Bewerbung löst Make dieses Event aus und setzt
               candidateName, candidateEmail, cvFileUrl als Prozessvariablen.
      </bpmn:documentation>
      <bpmn:outgoing>Flow_Application_Gather</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_ApplicationReceived" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Task_GatherApplications" name="Collect &#38; Structure Application" camunda:type="external" camunda:topic="collect-applications">
      <bpmn:documentation>
        AS-IS: HR Manager sammelt Bewerbung manuell aus Web-Portal.
        TO-BE: Make extrahiert automatisch alle Bewerbungsdaten aus E-Mail/Portal
               und speichert strukturiert in Google Sheets.
        Output: yearsExperience, educationLevel, languageLevel, cvFileUrl
      </bpmn:documentation>
      <bpmn:incoming>Flow_Application_Gather</bpmn:incoming>
      <bpmn:outgoing>Flow_Gather_CVScoring</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CVScoring" name="Score CV Automatically" camunda:type="external" camunda:topic="cv-scoring-python">
      <bpmn:documentation>
        AS-IS: HR Recruiter sichtet CV manuell, subjektive Beurteilung.
        TO-BE: Python Script berechnet automatisch CV Score (0-100, Hit Policy: SUM):
               yearsExperience → 10/25/40 Punkte
               educationLevel  → 10/20/40 Punkte
               languageLevel   → 0/10/20 Punkte
        Output: cvScore (Integer, 0-100)
      </bpmn:documentation>
      <bpmn:incoming>Flow_Gather_CVScoring</bpmn:incoming>
      <bpmn:outgoing>Flow_CVScoring_DMN</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="Task_DMNShortlist" name="DMN: Shortlist Decision" camunda:resultVariable="shortlistResult" camunda:decisionRef="Decision_CandidateEvaluation" camunda:mapDecisionResult="singleEntry">
      <bpmn:documentation>
        AS-IS: HR Recruiter entscheidet subjektiv ob Kandidat geeignet ist.
        TO-BE: Camunda DMN Decision Table (UNIQUE Hit Policy):
               cvScore &lt; 40   → "Absage"
               cvScore 40-69  → "Interview"
               cvScore &gt;= 70  → "Shortlist"
        Output: shortlistResult (String)
      </bpmn:documentation>
      <bpmn:incoming>Flow_CVScoring_DMN</bpmn:incoming>
      <bpmn:outgoing>Flow_0omxnex</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_ApplicationSuitable" name="Application suitable?">
      <bpmn:incoming>Flow_0omxnex</bpmn:incoming>
      <bpmn:outgoing>Flow_Suitable_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_1nnc321</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_SendCancellation" name="Send Cancellation">
      <bpmn:documentation>
        AS-IS: HR Recruiter schreibt Absage manuell per E-Mail (an Applier Pool).
        TO-BE: Make sendet automatisch personalisierte Absage-E-Mail via Gmail.
               Message Flow zum Applier Pool bleibt erhalten.
        Input:  candidateName, candidateEmail, jobTitle
        Output: rejectionEmailSent, rejectionEmailSentAt
      </bpmn:documentation>
      <bpmn:incoming>Flow_Suitable_No</bpmn:incoming>
      <bpmn:incoming>Flow_SecondInterviewNo_Reject</bpmn:incoming>
      <bpmn:incoming>Flow_HireNo_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Rejection_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Denied" name="Application denied">
      <bpmn:incoming>Flow_Rejection_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_CreateContract" name="Create Contract" camunda:formKey="embedded:app:forms/contract-form.html" camunda:assignee="${hrManager}">
      <bpmn:documentation>
        AS-IS: HR Manager erstellt Vertrag manuell in Word.
        TO-BE: Camunda Form — Felder: salary, startDate, contractType,
               workingHours, probationMonths.
               Daten werden für automatischen Vertragsversand via Make verwendet.
      </bpmn:documentation>
      <bpmn:incoming>Flow_HireYes_Contract</bpmn:incoming>
      <bpmn:outgoing>Flow_Contract_SendContract</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_SendContract" name="Send Contract" camunda:type="external" camunda:topic="send-contract-email">
      <bpmn:documentation>
        AS-IS: HR Manager versendet Vertrag manuell per E-Mail.
        TO-BE: Make befüllt Google Docs Template, generiert DocuSign-Link,
               sendet Vertrag automatisch an Kandidaten.
        Input:  salary, startDate, contractType, workingHours, candidateEmail
        Output: contractSent, docusignLink, contractSentAt
      </bpmn:documentation>
      <bpmn:incoming>Flow_Contract_SendContract</bpmn:incoming>
      <bpmn:outgoing>Flow_0byl64l</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ConductFirstInterview" name="Conduct first Interview" camunda:formKey="embedded:app:forms/interview-form.html" camunda:assignee="${hiringManager}">
      <bpmn:documentation>
        AS-IS: Hiring Manager führt Interview durch, Notizen auf Papier.
        TO-BE: Camunda Form — strukturierte Erfassung:
               interviewScore (0-10), technicalSkill (1-5), culturalFit (1-5),
               recommendation, interviewNotes.
      </bpmn:documentation>
      <bpmn:incoming>Flow_InviteFirst_Conduct</bpmn:incoming>
      <bpmn:outgoing>Flow_ConductFirst_Evaluate</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_EvaluateCandidate" name="Evaluate Candidate" camunda:formKey="embedded:app:forms/evaluation-form.html" camunda:assignee="${hiringManager}">
      <bpmn:documentation>
        AS-IS: Hiring Manager bewertet Kandidat subjektiv in Excel.
        TO-BE: Camunda Form — einheitliche Bewertungskriterien:
               overallRating (1-5), hiringDecision, salaryOffer, evaluationNotes.
               Ergebnis fliesst in DMN Final Decision.
      </bpmn:documentation>
      <bpmn:incoming>Flow_ConductFirst_Evaluate</bpmn:incoming>
      <bpmn:outgoing>Flow_Evaluate_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_InviteSecondInterview" name="Invite to Assessment?">
      <bpmn:incoming>Flow_Evaluate_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_SecondInterviewYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_SecondInterviewNo_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ConductSecondInterview" name="Conduct Assessment" camunda:formKey="embedded:app:forms/interview-form.html" camunda:assignee="${hiringManager}">
      <bpmn:documentation>
        AS-IS: Hiring Manager führt 2. Interview durch.
        TO-BE: Gleiches strukturiertes Camunda Form wie 1. Interview.
               Interview Score fliesst erneut in finale Entscheidung.
      </bpmn:documentation>
      <bpmn:incoming>Flow_InviteSecond_Conduct</bpmn:incoming>
      <bpmn:outgoing>Flow_0l4nvcf</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_HireCandidate" name="Hire Candidate?">
      <bpmn:incoming>Flow_AfterSecondEvaluate</bpmn:incoming>
      <bpmn:incoming>Flow_0qvw9z1</bpmn:incoming>
      <bpmn:outgoing>Flow_HireYes_Contract</bpmn:outgoing>
      <bpmn:outgoing>Flow_HireNo_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_13ubzbu" name="Assess Candidate">
      <bpmn:incoming>Flow_0l4nvcf</bpmn:incoming>
      <bpmn:outgoing>Flow_0qvw9z1</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ScheduleFirstInterview" name="Invite to first Interview">
      <bpmn:documentation>
        AS-IS: Hiring Manager lädt manuell zum 1. Interview ein (Message Flow → Applier).
        TO-BE: Make sendet automatisch Einladungs-E-Mail mit Calendly-Terminlink.
               Message Flow zum Applier Pool bleibt erhalten.
        Input:  candidateName, candidateEmail, jobTitle, hiringManager
        Output: interviewInvitationSent, interviewSchedulingLink
      </bpmn:documentation>
      <bpmn:incoming>Flow_1nnc321</bpmn:incoming>
      <bpmn:outgoing>Flow_InviteFirst_Conduct</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="Event_0h88k8b" name="Contract received">
      <bpmn:incoming>Flow_0byl64l</bpmn:incoming>
      <bpmn:outgoing>Flow_0x3qlno</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_12ko775" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Task_TriggerOnboarding" name="Trigger Onboarding" camunda:type="external" camunda:topic="trigger-onboarding">
      <bpmn:documentation>
        AS-IS: HR Manager koordiniert Onboarding manuell (IT-Zugänge, Büro, Team).
        TO-BE: Make triggert automatisch:
               Google Workspace Account erstellen, Willkommens-E-Mail,
               Slack-Benachrichtigung, Asana-Tasks, Google Calendar-Meetings.
        Output: onboardingTriggered, workEmail, onboardingTriggeredAt
      </bpmn:documentation>
      <bpmn:incoming>Flow_0x3qlno</bpmn:incoming>
      <bpmn:outgoing>Flow_Onboarding_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Onboarded" name="Employee onboarded">
      <bpmn:incoming>Flow_Onboarding_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_ScheduleSecondInterview" name="Invite to Assessment">
      <bpmn:documentation>
        AS-IS: Hiring Manager lädt manuell zum 2. Interview ein (Message Flow → Applier).
        TO-BE: Make sendet automatisch 2. Einladungs-E-Mail mit neuem Calendly-Link.
               Message Flow zum Applier Pool bleibt erhalten.
        Input:  candidateName, candidateEmail, jobTitle, hiringManager
        Output: secondInterviewInvitationSent, secondInterviewSchedulingLink
      </bpmn:documentation>
      <bpmn:incoming>Flow_SecondInterviewYes</bpmn:incoming>
      <bpmn:outgoing>Flow_InviteSecond_Conduct</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_Application_Gather" sourceRef="Event_ApplicationReceived" targetRef="Task_GatherApplications" />
    <bpmn:sequenceFlow id="Flow_Gather_CVScoring" sourceRef="Task_GatherApplications" targetRef="Task_CVScoring" />
    <bpmn:sequenceFlow id="Flow_CVScoring_DMN" sourceRef="Task_CVScoring" targetRef="Task_DMNShortlist" />
    <bpmn:sequenceFlow id="Flow_0omxnex" sourceRef="Task_DMNShortlist" targetRef="Gateway_ApplicationSuitable" />
    <bpmn:sequenceFlow id="Flow_Suitable_No" name="No" sourceRef="Gateway_ApplicationSuitable" targetRef="Task_SendCancellation" />
    <bpmn:sequenceFlow id="Flow_1nnc321" name="Yes" sourceRef="Gateway_ApplicationSuitable" targetRef="Task_ScheduleFirstInterview" />
    <bpmn:sequenceFlow id="Flow_SecondInterviewNo_Reject" name="No" sourceRef="Gateway_InviteSecondInterview" targetRef="Task_SendCancellation" />
    <bpmn:sequenceFlow id="Flow_HireNo_Reject" name="No" sourceRef="Gateway_HireCandidate" targetRef="Task_SendCancellation" />
    <bpmn:sequenceFlow id="Flow_Rejection_End" sourceRef="Task_SendCancellation" targetRef="EndEvent_Denied" />
    <bpmn:sequenceFlow id="Flow_HireYes_Contract" name="Yes" sourceRef="Gateway_HireCandidate" targetRef="Task_CreateContract" />
    <bpmn:sequenceFlow id="Flow_Contract_SendContract" sourceRef="Task_CreateContract" targetRef="Task_SendContract" />
    <bpmn:sequenceFlow id="Flow_0byl64l" sourceRef="Task_SendContract" targetRef="Event_0h88k8b" />
    <bpmn:sequenceFlow id="Flow_InviteFirst_Conduct" sourceRef="Task_ScheduleFirstInterview" targetRef="Task_ConductFirstInterview" />
    <bpmn:sequenceFlow id="Flow_ConductFirst_Evaluate" sourceRef="Task_ConductFirstInterview" targetRef="Task_EvaluateCandidate" />
    <bpmn:sequenceFlow id="Flow_Evaluate_Gateway" sourceRef="Task_EvaluateCandidate" targetRef="Gateway_InviteSecondInterview" />
    <bpmn:sequenceFlow id="Flow_SecondInterviewYes" name="Yes" sourceRef="Gateway_InviteSecondInterview" targetRef="Task_ScheduleSecondInterview" />
    <bpmn:sequenceFlow id="Flow_InviteSecond_Conduct" sourceRef="Task_ScheduleSecondInterview" targetRef="Task_ConductSecondInterview" />
    <bpmn:sequenceFlow id="Flow_0l4nvcf" sourceRef="Task_ConductSecondInterview" targetRef="Activity_13ubzbu" />
    <bpmn:sequenceFlow id="Flow_0qvw9z1" sourceRef="Activity_13ubzbu" targetRef="Gateway_HireCandidate" />
    <bpmn:sequenceFlow id="Flow_0x3qlno" sourceRef="Event_0h88k8b" targetRef="Task_TriggerOnboarding" />
    <bpmn:sequenceFlow id="Flow_Onboarding_End" sourceRef="Task_TriggerOnboarding" targetRef="EndEvent_Onboarded" />
  </bpmn:process>
  <bpmn:process id="Process_1omo9f6">
    <bpmn:startEvent id="Event_0qepplw" name="New position requested">
      <bpmn:outgoing>Flow_192n8mk</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Activity_1p2v3ff" name="Define position">
      <bpmn:incoming>Flow_192n8mk</bpmn:incoming>
      <bpmn:outgoing>Flow_0i15o4x</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_0g5d5l4" name="Posit Job to Portals">
      <bpmn:incoming>Flow_0i15o4x</bpmn:incoming>
      <bpmn:outgoing>Flow_0lsjsdp</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="Event_1661x8d" name="30 days">
      <bpmn:incoming>Flow_0lsjsdp</bpmn:incoming>
      <bpmn:outgoing>Flow_1093f2n</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1vc8cwr" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Activity_1gk1fqn" name="Close Job postings">
      <bpmn:incoming>Flow_1093f2n</bpmn:incoming>
      <bpmn:outgoing>Flow_0v6m1vw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_0pegjj4" name="Job posting closed">
      <bpmn:incoming>Flow_0v6m1vw</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_192n8mk" sourceRef="Event_0qepplw" targetRef="Activity_1p2v3ff" />
    <bpmn:sequenceFlow id="Flow_0i15o4x" sourceRef="Activity_1p2v3ff" targetRef="Activity_0g5d5l4" />
    <bpmn:sequenceFlow id="Flow_0lsjsdp" sourceRef="Activity_0g5d5l4" targetRef="Event_1661x8d" />
    <bpmn:sequenceFlow id="Flow_1093f2n" sourceRef="Event_1661x8d" targetRef="Activity_1gk1fqn" />
    <bpmn:sequenceFlow id="Flow_0v6m1vw" sourceRef="Activity_1gk1fqn" targetRef="Event_0pegjj4" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_TOBE_v2">
      <bpmndi:BPMNShape id="Participant_Company_di" bpmnElement="Participant_Company" isHorizontal="true">
        <dc:Bounds x="190" y="630" width="2820" height="618" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_HiringManager_di" bpmnElement="Lane_HiringManager" isHorizontal="true">
        <dc:Bounds x="220" y="1028" width="2790" height="220" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_HRRecruiter_di" bpmnElement="Lane_HRRecruiter" isHorizontal="true">
