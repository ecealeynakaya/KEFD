      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Denied_di" bpmnElement="EndEvent_Denied">
        <dc:Bounds x="1242" y="822" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1216" y="865" width="89" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreateContract_di" bpmnElement="Task_CreateContract">
        <dc:Bounds x="2340" y="671" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendContract_di" bpmnElement="Task_SendContract">
        <dc:Bounds x="2500" y="671" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ConductFirstInterview_di" bpmnElement="Task_ConductFirstInterview">
        <dc:Bounds x="1420" y="1068" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EvaluateCandidate_di" bpmnElement="Task_EvaluateCandidate">
        <dc:Bounds x="1570" y="1068" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InviteSecondInterview_di" bpmnElement="Gateway_InviteSecondInterview" isMarkerVisible="true">
        <dc:Bounds x="1725" y="1083" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1716" y="1046" width="68" height="27" />
